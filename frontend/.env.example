# po-required-amount environment variables
# Copy to .env.local and fill in values

# Soroban verifier contract ID (after deployment)
# Get this from: stellar contract deploy ...
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=PLACEHOLDER_DEPLOY_CONTRACT_FIRST

# Optional: override RPC endpoint
# NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org
